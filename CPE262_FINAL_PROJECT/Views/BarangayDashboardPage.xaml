                                                   Foreground="#C05050" Visibility="Collapsed"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Style="{StaticResource PrimaryBtnStyle}"
                                                    Click="EvacMap_ConfirmOcc_Click">
                                                <TextBlock Text="UPDATE" FontFamily="Consolas"
                                                           FontSize="9" Foreground="White"
                                                           FontWeight="Bold" CharacterSpacing="80"/>
                                            </Button>
                                            <Button Style="{StaticResource GhostBtnStyle}"
                                                    Click="EvacMap_CancelOcc_Click">
                                                <TextBlock Text="CANCEL" FontFamily="Consolas"
                                                           FontSize="9" Foreground="#3A5570"
                                                           CharacterSpacing="60"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Padding="14,12">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="PIN LEGEND" FontFamily="Consolas"
                                                   FontSize="9" Foreground="#3A5570"
                                                   CharacterSpacing="150" FontWeight="Bold"/>
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Width="10" Height="10" Background="#C05050"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Text="Barangay Center (yours)"
                                                           FontFamily="Consolas" FontSize="9"
                                                           Foreground="#7A9BB8"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Width="10" Height="10" Background="#4A8EC2"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Text="Cross-Barangay (click to request)"
                                                           FontFamily="Consolas" FontSize="9"
                                                           Foreground="#7A9BB8"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Width="10" Height="10" Background="#4A9A60"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Text="City-Level Center"
                                                           FontFamily="Consolas" FontSize="9"
                                                           Foreground="#7A9BB8"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Border x:Name="WarningOverlay" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#CC000000" Visibility="Collapsed">
            <Border Background="#0C1A26" BorderThickness="1,0,0,0" BorderBrush="#7A2020"
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Border Padding="20,14" Background="#1A0808"
                            BorderThickness="0,0,0,1" BorderBrush="#2A1010">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="!" FontFamily="Consolas" FontSize="16"
                                       Foreground="#C05050" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="WARNING" FontFamily="Consolas" FontSize="12"
                                       Foreground="#C05050" FontWeight="Bold" CharacterSpacing="150"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="20,18">
                        <TextBlock x:Name="WarningMessage" Text=""
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#C8D8E8" TextWrapping="Wrap" LineHeight="20"/>
                    </Border>
                    <Border Padding="20,12" BorderThickness="0,1,0,0" BorderBrush="#172435">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Style="{StaticResource GhostBtnStyle}"
                                    Click="CloseWarningOverlay_Click">
                                <TextBlock Text="CANCEL" FontFamily="Consolas" FontSize="9"
                                           Foreground="#3A5570" CharacterSpacing="80"/>
                            </Button>
                            <Button x:Name="WarningConfirmBtn"
                                    Background="#7A2020" BorderThickness="0"
                                    Padding="16,8" CornerRadius="0"
                                    Click="ConfirmWarning_Click">
                                <TextBlock x:Name="WarningConfirmLabel" Text="CONFIRM"
                                           FontFamily="Consolas" FontSize="9"
                                           Foreground="White" FontWeight="Bold" CharacterSpacing="80"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>
        <Border x:Name="ReassignCenterOverlay" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#CC000000" Visibility="Collapsed">
            <Border Background="#0C1A26" BorderThickness="1" BorderBrush="#1A4A7A"
                    Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Border Padding="22,18" BorderThickness="0,0,0,1" BorderBrush="#172435">
                        <Grid>
                            <StackPanel Spacing="2">
                                <TextBlock Text="REASSIGN EVACUATION CENTER" FontFamily="Consolas"
                                           FontSize="12" FontWeight="Bold" Foreground="#C8D8E8"
                                           CharacterSpacing="100"/>
                                <TextBlock x:Name="ReassignFamilyLabel" Text="Family: —"
                                           FontFamily="Consolas" FontSize="9" Foreground="#4A8EC2"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    Click="CloseReassignOverlay_Click" Padding="8">
                                <TextBlock Text="x" FontFamily="Consolas" FontSize="13" Foreground="#3A5570"/>
                            </Button>
                        </Grid>
                    </Border>
                    <StackPanel Padding="22,18" Spacing="14">
                        <StackPanel Spacing="5">
                            <TextBlock Text="SELECT NEW EVACUATION CENTER *" FontFamily="Consolas"
                                       FontSize="8" Foreground="#3A5570" CharacterSpacing="180" FontWeight="Bold"/>
                            <ComboBox x:Name="ReassignCenterPicker" HorizontalAlignment="Stretch"
                                      FontFamily="Consolas" FontSize="10" Background="#09131C"
                                      Foreground="White" BorderBrush="#253A52" CornerRadius="0" Padding="10,8"/>
                        </StackPanel>
                        <TextBlock x:Name="ReassignErrorMsg" Text="" FontFamily="Consolas" FontSize="9"
                                   Foreground="#C05050" Visibility="Collapsed" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Border Padding="22,14" BorderThickness="0,1,0,0" BorderBrush="#172435">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Style="{StaticResource GhostBtnStyle}" Click="CloseReassignOverlay_Click">
                                <TextBlock Text="CANCEL" FontFamily="Consolas" FontSize="9"
                                           Foreground="#3A5570" CharacterSpacing="80"/>
                            </Button>
                            <Button Style="{StaticResource PrimaryBtnStyle}" Click="SubmitReassign_Click">
                                <TextBlock Text="CONFIRM REASSIGN" FontFamily="Consolas" FontSize="9"
                                           Foreground="White" FontWeight="Bold" CharacterSpacing="80"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>
        <Grid x:Name="CenterDetailsOverlay" Grid.Column="0" Grid.ColumnSpan="2"
              Visibility="Collapsed">
            <Border Background="#CC000000"/>
            <Border Background="#0C1A26" BorderThickness="1" BorderBrush="#1A4A7A"
                    Width="640" MaxHeight="620"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="22,16" BorderThickness="0,0,0,1" BorderBrush="#172435">
                        <Grid>
                            <StackPanel Spacing="3">
                                <TextBlock x:Name="CenterDetailsTitle" Text="CENTER DETAILS"
                                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                           Foreground="#C8D8E8" CharacterSpacing="120"/>
                                <TextBlock x:Name="CenterDetailsSubtitle" Text=""
                                           FontFamily="Consolas" FontSize="9" Foreground="#2A4060"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    Click="CloseCenterDetailsOverlay_Click" Padding="8">
                                <TextBlock Text="x" FontFamily="Consolas" FontSize="13" Foreground="#3A5570"/>
                            </Button>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1">
                        <Border Background="#09131C" Padding="18,8,18,8"
                                BorderThickness="0,0,0,1" BorderBrush="#172435">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="HEAD OF FAMILY" FontFamily="Consolas"
                                           FontSize="8" Foreground="#2A4060" CharacterSpacing="180"/>
                                <TextBlock Grid.Column="1" Text="MBRS" FontFamily="Consolas"
                                           FontSize="8" Foreground="#2A4060" CharacterSpacing="180"/>
                                <TextBlock Grid.Column="2" Text="RELIEF" FontFamily="Consolas"
                                           FontSize="8" Foreground="#2A4060" CharacterSpacing="180"/>
                                <TextBlock Grid.Column="3" Text="BARANGAY" FontFamily="Consolas"
                                           FontSize="8" Foreground="#2A4060" CharacterSpacing="180"/>
                            </Grid>
                        </Border>
                        <ScrollViewer MaxHeight="470" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CenterDetailsFamiliesPanel"/>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <Border x:Name="ToastBanner" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#091A10" BorderThickness="1,0,0,0" BorderBrush="#1A6A30"
                Padding="16,10" Width="300" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,24,24" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Rectangle Width="2" Fill="#2A9A40" VerticalAlignment="Stretch"/>
                <TextBlock x:Name="ToastMessage" Text="Action completed" FontFamily="Consolas"
                           FontSize="10" Foreground="#8AC8A0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
