<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="CPE262_FINAL_PROJECT.Views.BarangayDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#09131C">

    <Page.Resources>

        <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius"               Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#0F2035"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Indicator" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0.5"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#162840"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="0" Padding="0,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle x:Name="Indicator" Grid.Column="0"
                                               Fill="#4A8EC2" Opacity="0"/>
                                    <ContentPresenter Grid.Column="1" Margin="14,10,12,10"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background"                 Value="#1A4A7A"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="16,8"/>
            <Setter Property="CornerRadius"               Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#215E9A"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#133A60"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="Bg" Background="#1A4A7A" CornerRadius="0" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtnStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderBrush"                Value="#253A52"/>
            <Setter Property="BorderThickness"            Value="1"/>
            <Setter Property="Padding"                    Value="14,7"/>
            <Setter Property="CornerRadius"               Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#0F2035"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#162840"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="Bg" Background="Transparent" BorderBrush="#253A52"
                                    BorderThickness="1" CornerRadius="0" Padding="14,7">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutStyle" TargetType="Button">
            <Setter Property="Background"          Value="Transparent"/>
            <Setter Property="BorderBrush"         Value="#253A52"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="Padding"             Value="0,7"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius"        Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#0F2035"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Lbl" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#4A8EC2"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="Bg" Background="Transparent" BorderBrush="#253A52"
                                    BorderThickness="1" CornerRadius="0">
                                <TextBlock x:Name="Lbl" Text="[ LOGOUT ]"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="#3A5570"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Padding="0,7" CharacterSpacing="80"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#0C1A26"
                BorderThickness="0,0,1,0" BorderBrush="#172435">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="18,22,18,18" Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="FIRETRACK" FontSize="16" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="#C8D8E8"
                                   CharacterSpacing="200"/>
                        <TextBlock Text="DISASTER RESPONSE SYSTEM"
                                   FontFamily="Consolas" FontSize="8"
                                   Foreground="#2A4060" CharacterSpacing="120"/>
                    </StackPanel>
                    <Border Background="#0F2035" BorderThickness="0,0,0,0"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Rectangle Width="2" Height="12" Fill="#4A8EC2" VerticalAlignment="Center"/>
                            <TextBlock Text="BARANGAY OFFICIAL" FontFamily="Consolas" FontSize="9"
                                       Foreground="#4A8EC2" FontWeight="Bold" CharacterSpacing="100"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Rectangle Grid.Row="0" Height="1" Fill="#172435" VerticalAlignment="Bottom"/>

                <StackPanel Grid.Row="1" Spacing="0" Padding="0,16,0,0">

                    <TextBlock Text="NAVIGATION" FontFamily="Consolas" FontSize="8"
                               Foreground="#1E3050" CharacterSpacing="250"
                               Margin="18,0,0,10" FontWeight="Bold"/>

                    <Button x:Name="NavOverviewBtn" Style="{StaticResource NavItemStyle}"
                            Click="NavOverview_Click">
                        <StackPanel Spacing="1">
                            <TextBlock Text="■  OVERVIEW" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#7A9BB8" CharacterSpacing="80"/>
                            <TextBlock Text="Dashboard summary"
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#2A4060"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="#101E2E" Margin="18,4,18,4"/>

                    <Button x:Name="NavFamiliesBtn" Style="{StaticResource NavItemStyle}"
                            Click="NavFamilies_Click">
                        <StackPanel Spacing="1">
                            <TextBlock Text="▤  AFFECTED FAMILIES" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#7A9BB8" CharacterSpacing="80"/>
                            <TextBlock Text="Register &amp; manage"
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#2A4060"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="#101E2E" Margin="18,4,18,4"/>

                    <Button x:Name="NavCentersBtn" Style="{StaticResource NavItemStyle}"
                            Click="NavCenters_Click">
                        <StackPanel Spacing="1">
                            <TextBlock Text="▦  EVACUATION CENTERS" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#7A9BB8" CharacterSpacing="80"/>
                            <TextBlock Text="Capacity &amp; occupancy"
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#2A4060"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="#101E2E" Margin="18,4,18,4"/>

                    <Button x:Name="NavIncidentsBtn" Style="{StaticResource NavItemStyle}"
                            Click="NavIncidents_Click">
                        <StackPanel Spacing="1">
                            <TextBlock Text="▲  INCIDENT REPORTS" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#7A9BB8" CharacterSpacing="80"/>
                            <TextBlock Text="Active fires in barangay"
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#2A4060"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="#101E2E" Margin="18,4,18,4"/>

                    <Button x:Name="NavAnalysisBtn" Style="{StaticResource NavItemStyle}"
                            Click="NavAnalysis_Click">
                        <StackPanel Spacing="1">
                            <TextBlock Text="&#x25C8;  ANALYSIS" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#7A9BB8" CharacterSpacing="80"/>
                            <TextBlock Text="Charts &amp; statistics"
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#2A4060"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <Border Grid.Row="2" BorderThickness="0,1,0,0"
                        BorderBrush="#172435" Padding="18,16">
                    <StackPanel Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="OperatorName" Text="OFFICIAL NAME"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#C8D8E8" FontWeight="Bold"/>
                            <TextBlock x:Name="OperatorBarangay" Text="Barangay —"
                                       FontFamily="Consolas" FontSize="9" Foreground="#2A4060"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="6" Height="6" Fill="#2A6A40"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ClockText" Text="00:00:00"
                                       FontFamily="Consolas" FontSize="10" Foreground="#2A4060"/>
                        </StackPanel>
                        <Button Style="{StaticResource LogoutStyle}" Click="Logout_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0C1A26"
                    BorderThickness="0,0,0,1" BorderBrush="#172435" Padding="24,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                        <TextBlock x:Name="TopBarTitle" Text="OVERVIEW"
                                   FontFamily="Consolas" FontSize="13"
                                   FontWeight="Bold" Foreground="#C8D8E8" CharacterSpacing="150"/>
                        <TextBlock Text=" / " FontFamily="Consolas" FontSize="13"
                                   Foreground="#1E3050" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TopBarSubtitle" Text="Barangay Response Dashboard"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#3A5570" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="1" BorderBrush="#172435"
                            Padding="12,5">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Rectangle Width="6" Height="6" Fill="#2A7A40" VerticalAlignment="Center"/>
                            <TextBlock Text="SYSTEM ONLINE" FontFamily="Consolas" FontSize="9"
                                       Foreground="#2A7A40" FontWeight="Bold" CharacterSpacing="100"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer x:Name="SectionOverview" Grid.Row="1" Padding="24,20">
                <StackPanel Spacing="20">

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0C1A26"
                                BorderThickness="1" BorderBrush="#172435" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#1A4A7A"/>
                                <StackPanel Grid.Column="1" Spacing="6" Padding="16,16">
                                    <TextBlock Text="TOTAL FAMILIES" FontFamily="Consolas" FontSize="8"
                                               Foreground="#3A5570" CharacterSpacing="200"/>
                                    <TextBlock x:Name="StatTotalFamilies" Text="—"
                                               FontFamily="Consolas" FontSize="30"
                                               FontWeight="Bold" Foreground="#4A8EC2"/>
                                    <TextBlock Text="Registered displaced" FontFamily="Consolas"
                                               FontSize="8" Foreground="#1E3050"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="#0C1A26"
                                BorderThickness="1" BorderBrush="#172435">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#1A4A7A"/>
                                <StackPanel Grid.Column="1" Spacing="6" Padding="16,16">
                                    <TextBlock Text="PERSONS DISPLACED" FontFamily="Consolas" FontSize="8"
                                               Foreground="#3A5570" CharacterSpacing="200"/>
                                    <TextBlock x:Name="StatPersonsDisplaced" Text="—"
                                               FontFamily="Consolas" FontSize="30"
                                               FontWeight="Bold" Foreground="#4A8EC2"/>
                                    <TextBlock Text="Total head count" FontFamily="Consolas"
                                               FontSize="8" Foreground="#1E3050"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#0C1A26"
                                BorderThickness="1" BorderBrush="#172435">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#1A4A7A"/>
                                <StackPanel Grid.Column="1" Spacing="6" Padding="16,16">
                                    <TextBlock Text="EVAC CENTERS" FontFamily="Consolas" FontSize="8"
                                               Foreground="#3A5570" CharacterSpacing="200"/>
                                    <TextBlock x:Name="StatEvacCenters" Text="—"
                                               FontFamily="Consolas" FontSize="30"
                                               FontWeight="Bold" Foreground="#4A8EC2"/>
                                    <TextBlock Text="Active in barangay" FontFamily="Consolas"
                                               FontSize="8" Foreground="#1E3050"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="3" Background="#120A0A"
                                BorderThickness="1" BorderBrush="#2A1010">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#7A2020"/>
                                <StackPanel Grid.Column="1" Spacing="6" Padding="16,16">
                                    <TextBlock Text="REPEAT DISPLACED" FontFamily="Consolas" FontSize="8"
                                               Foreground="#5A3030" CharacterSpacing="200"/>
                                    <TextBlock x:Name="StatRepeatDisplaced" Text="—"
                                               FontFamily="Consolas" FontSize="30"
                                               FontWeight="Bold" Foreground="#C05050"/>
                                    <TextBlock Text="Previously registered" FontFamily="Consolas"
                                               FontSize="8" Foreground="#3A2020"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0C1A26"
                                BorderThickness="1" BorderBrush="#172435">
                            <StackPanel>
                                <Border Padding="18,14" BorderThickness="0,0,0,1" BorderBrush="#172435">
                                    <Grid>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="RECENT FAMILIES" FontFamily="Consolas"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#C8D8E8" CharacterSpacing="120"/>
                                            <TextBlock Text="Last 10 registered"
                                                       FontFamily="Consolas" FontSize="9" Foreground="#2A4060"/>
                                        </StackPanel>
                                        <Button Style="{StaticResource PrimaryBtnStyle}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Click="OpenRegisterFamilyDialog_Click">
                                            <TextBlock Text="+ REGISTER FAMILY" FontFamily="Consolas"
                                                       FontSize="9" Foreground="White" FontWeight="Bold"
                                                       CharacterSpacing="60"/>
                                        </Button>
                                    </Grid>
                                </Border>
                                <Border Background="#09131C" Padding="18,8,18,8">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="85"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="HEAD OF FAMILY"
                                                   FontFamily="Consolas" FontSize="8"
                                                   Foreground="#2A4060" CharacterSpacing="180"/>
                                        <TextBlock Grid.Column="1" Text="MBRS"
                                                   FontFamily="Consolas" FontSize="8"
                                                   Foreground="#2A4060" CharacterSpacing="180"/>
                                        <TextBlock Grid.Column="2" Text="EVAC CENTER"
                                                   FontFamily="Consolas" FontSize="8"
                                                   Foreground="#2A4060" CharacterSpacing="180"/>
                                        <TextBlock Grid.Column="3" Text="RELIEF"
                                                   FontFamily="Consolas" FontSize="8"
                                                   Foreground="#2A4060" CharacterSpacing="180"/>
                                    </Grid>
                                </Border>
                                <StackPanel x:Name="OverviewFamiliesPanel"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="12">

                            <Border Background="#0C1A26" BorderThickness="1" BorderBrush="#172435">
                                <StackPanel>
                                    <Border Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="#172435">
                                        <Grid>
                                            <TextBlock Text="EVACUATION CENTERS" FontFamily="Consolas"
                                                       FontSize="10" FontWeight="Bold" Foreground="#C8D8E8"
                                                       CharacterSpacing="80"/>
                                            <Button Style="{StaticResource GhostBtnStyle}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Click="OpenAddCenterDialog_Click">
                                                <TextBlock Text="+" FontFamily="Consolas"
                                                           FontSize="13" Foreground="#4A8EC2" FontWeight="Bold"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="OverviewCentersPanel" Padding="0,4,0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#0C1A26" BorderThickness="1" BorderBrush="#172435">
                                <StackPanel>
                                    <Border Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="#172435">
                                        <TextBlock Text="QUICK ACTIONS" FontFamily="Consolas"
                                                   FontSize="10" FontWeight="Bold" Foreground="#C8D8E8"
                                                   CharacterSpacing="80"/>
                                    </Border>
                                    <StackPanel Padding="12,10" Spacing="6">
                                        <Button Style="{StaticResource GhostBtnStyle}"
                                                HorizontalAlignment="Stretch"
                                                Click="OpenRegisterFamilyDialog_Click">
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="+ Register New Family"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="#C8D8E8" FontWeight="Bold"/>
                                                <TextBlock Text="Log a displaced household"
                                                           FontFamily="Consolas" FontSize="8"
                                                           Foreground="#2A4060"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource GhostBtnStyle}"
                                                HorizontalAlignment="Stretch" Click="NavCenters_Click">
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="▦ Manage Evac Centers"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="#C8D8E8" FontWeight="Bold"/>
                                                <TextBlock Text="Update occupancy / add center"
                                                           FontFamily="Consolas" FontSize="8"
                                                           Foreground="#2A4060"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource GhostBtnStyle}"
                                                HorizontalAlignment="Stretch" Click="NavIncidents_Click">
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="▲ View Incident Reports"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="#C8D8E8" FontWeight="Bold"/>
                                                <TextBlock Text="See active fires in barangay"
                                                           FontFamily="Consolas" FontSize="8"
                                                   Foreground="#2A4060"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="OverviewCitizenReportsBtn"
                                                Style="{StaticResource GhostBtnStyle}"
                                                HorizontalAlignment="Stretch"
                                                Click="NavCitizenReports_Click">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="1">
                                                    <TextBlock Text="&gt; Citizen Reports"
                                                               FontFamily="Consolas" FontSize="10"
                                                               Foreground="#C8D8E8" FontWeight="Bold"/>
                                                    <TextBlock Text="Verify resident-submitted tips"
                                                               FontFamily="Consolas" FontSize="8"
                                                               Foreground="#2A4060"/>
                                                </StackPanel>
                                                <Border x:Name="BrgyCitizenReportsBadge" Grid.Column="1"
                                                        Background="#2A1E06" Padding="6,2,6,2"
                                                        VerticalAlignment="Center" Visibility="Collapsed">
                                                    <TextBlock x:Name="BrgyCitizenReportsBadgeCount" Text="0"
                                                               FontFamily="Consolas" FontSize="9"
                                                               Foreground="#C89A30" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="SectionFamilies" Grid.Row="1" Padding="24,20"
                          Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <Border Background="#0C1A26" BorderThickness="1" BorderBrush="#172435">
                        <StackPanel>
                            <Border Padding="18,14" BorderThickness="0,0,0,1" BorderBrush="#172435">
                                <Grid>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="AFFECTED FAMILIES" FontFamily="Consolas"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#C8D8E8" CharacterSpacing="120"/>
                                        <TextBlock x:Name="FamiliesSubtitle"
                                                   Text="All families registered under barangay incidents"
                                                   FontFamily="Consolas" FontSize="9" Foreground="#2A4060"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource PrimaryBtnStyle}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Click="OpenRegisterFamilyDialog_Click">
                                        <TextBlock Text="+ REGISTER NEW FAMILY" FontFamily="Consolas"
                                                   FontSize="9" Foreground="White" FontWeight="Bold"
