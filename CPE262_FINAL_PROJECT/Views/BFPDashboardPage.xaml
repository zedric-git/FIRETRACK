<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPE262_FINAL_PROJECT.Views.BFPDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#16202B" BorderThickness="0,0,0,1" BorderBrush="#2A3F52">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="FIRETRACK" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas" Foreground="White"
                               CharacterSpacing="150" VerticalAlignment="Center"/>
                    <Border Background="#FF5252" CornerRadius="3" Padding="8,2">
                        <TextBlock Text="BFP OFFICER" FontFamily="Consolas" FontSize="10"
                                   Foreground="White" FontWeight="Bold" CharacterSpacing="150"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="ClockText" FontFamily="Consolas" FontSize="11" Foreground="#4A6B8A"/>
                    <TextBlock Text="|" Foreground="#2A3F52"/>
                    <TextBlock x:Name="OperatorText" FontFamily="Consolas" FontSize="11" Foreground="#A0B4C8"/>
                    <Button Content="LOGOUT" Click="Logout_Click"
                            Background="Transparent" BorderBrush="#FF8070" BorderThickness="1"
                            Foreground="#FF8070" FontFamily="Consolas" FontSize="10"
                            Padding="10,4" CornerRadius="3"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E2D3D"
                        BorderThickness="0,0,0,1" BorderBrush="#2A3F52" Padding="12,0">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="INCIDENT MAP — CEBU CITY"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#A0B4C8" CharacterSpacing="100"
                                   VerticalAlignment="Center"/>
                        <Rectangle Width="1" Height="20" Fill="#2A3F52"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="🔴" FontSize="12"/>
                            <TextBlock Text="Active Spread" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="🟠" FontSize="12"/>
                            <TextBlock Text="Under Control" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="⚪" FontSize="12"/>
                            <TextBlock Text="Fire Out" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>
                        <Rectangle Width="1" Height="20" Fill="#2A3F52"/>
                        <Button Content="↻ REFRESH MARKERS" Click="RefreshMarkers_Click"
                                Background="Transparent" BorderBrush="#2A3F52" BorderThickness="1"
                                Foreground="#4A6B8A" FontFamily="Consolas" FontSize="10"
                                Padding="10,4" CornerRadius="3"/>
                        <Rectangle Width="1" Height="20" Fill="#2A3F52"/>
                        <Button x:Name="AnalysisToggleBtn"
                                Content="ANALYSIS" Click="AnalysisToggle_Click"
                                Background="Transparent" BorderBrush="#FFC107" BorderThickness="1"
                                Foreground="#FFC107" FontFamily="Consolas" FontSize="10"
                                FontWeight="Bold" Padding="10,4" CornerRadius="3"/>
                        <Button x:Name="CitizenReportsToggleBtn"
                                Click="CitizenReportsToggle_Click"
                                Background="Transparent" BorderBrush="#4CAF50" BorderThickness="1"
                                Foreground="#4CAF50" FontFamily="Consolas" FontSize="10"
                                FontWeight="Bold" Padding="10,4" CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="CITIZEN REPORTS"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="#4CAF50" FontWeight="Bold"/>
                                <Border x:Name="BfpCitizenReportsBadge" Grid.Column="1"
                                        Background="#2A1E06" Padding="6,1,6,1"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="BfpCitizenReportsBadgeCount" Text="0"
                                               FontFamily="Consolas" FontSize="9"
                                               Foreground="#FFC107" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <WebView2 x:Name="MapWebView"
                              NavigationCompleted="MapWebView_NavigationCompleted"/>
                    <Border x:Name="MapLoadingOverlay" Background="#0D1B2A">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                            <ProgressRing IsActive="True" Width="40" Height="40" Foreground="#FF8070"/>
                            <TextBlock Text="LOADING MAP..." FontFamily="Consolas"
                                       FontSize="12" Foreground="#FF9B8A"
                                       CharacterSpacing="150" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
            <Border x:Name="RegisterFormPanel" Background="#16202B"
                    BorderThickness="1,0,0,0" BorderBrush="#2A3F52">
                <ScrollViewer Padding="20,16">
                    <StackPanel Spacing="16">

                        <StackPanel Spacing="4">
                            <TextBlock Text="REGISTER FIRE INCIDENT"
                                       FontFamily="Consolas" FontSize="13"
                                       FontWeight="Bold" Foreground="White" CharacterSpacing="100"/>
                            <TextBlock Text="Drop a pin on the map to auto-fill location fields"
                                       FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>

                        <Button x:Name="DropPinBtn" Click="DropPin_Click"
                                HorizontalAlignment="Stretch" Height="44"
                                Background="#1E3A2A" CornerRadius="3"
                                BorderBrush="#4CAF50" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="📍" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DropPinText" Text="DROP PIN ON MAP"
                                           FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                           Foreground="#4CAF50" CharacterSpacing="80"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="LATITUDE" FontFamily="Consolas" FontSize="10"
                                           Foreground="#A0B4C8" CharacterSpacing="150"/>
                                <Border Background="#1A2B1A" CornerRadius="3"
                                        BorderThickness="1" BorderBrush="#4CAF50">
                                    <TextBox x:Name="LatBox" PlaceholderText="auto-filled"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="#4CAF50" PlaceholderForeground="#4A6B8A"
                                             FontFamily="Consolas" FontSize="12" Padding="10,9"
                                             IsReadOnly="True"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="LONGITUDE" FontFamily="Consolas" FontSize="10"
                                           Foreground="#A0B4C8" CharacterSpacing="150"/>
                                <Border Background="#1A2B1A" CornerRadius="3"
                                        BorderThickness="1" BorderBrush="#4CAF50">
                                    <TextBox x:Name="LngBox" PlaceholderText="auto-filled"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="#4CAF50" PlaceholderForeground="#4A6B8A"
                                             FontFamily="Consolas" FontSize="12" Padding="10,9"
                                             IsReadOnly="True"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="6">
                            <TextBlock Text="BARANGAY" FontFamily="Consolas" FontSize="10"
                                       Foreground="#A0B4C8" CharacterSpacing="150"/>
                            <Border x:Name="BarangayFieldBorder" Background="#1E2D3D" CornerRadius="3"
                                    BorderThickness="1" BorderBrush="#2A3F52">
                                <TextBox x:Name="BarangayBox" PlaceholderText="Auto-filled from pin drop..."
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="White" PlaceholderForeground="#4A6B8A"
                                         FontFamily="Consolas" FontSize="12" Padding="12,10"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="SITIO / STREET" FontFamily="Consolas" FontSize="10"
                                       Foreground="#A0B4C8" CharacterSpacing="150"/>
                            <Border x:Name="SitioFieldBorder" Background="#1E2D3D" CornerRadius="3"
                                    BorderThickness="1" BorderBrush="#2A3F52">
                                <TextBox x:Name="SitioBox" PlaceholderText="Auto-filled from pin drop..."
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="White" PlaceholderForeground="#4A6B8A"
                                         FontFamily="Consolas" FontSize="12" Padding="12,10"/>
                            </Border>
                        </StackPanel>

                        <Rectangle Height="1" Fill="#2A3F52"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="ALARM LEVEL" FontFamily="Consolas" FontSize="10"
                                       Foreground="#A0B4C8" CharacterSpacing="150"/>
                            <Border Background="#1E2D3D" CornerRadius="3"
                                    BorderThickness="1" BorderBrush="#2A3F52">
                                <ComboBox x:Name="AlarmLevelBox"
                                          Background="Transparent" BorderThickness="0"
                                          Foreground="White" FontFamily="Consolas" FontSize="12"
                                          HorizontalAlignment="Stretch" Padding="10,10">
                                    <ComboBoxItem Content="Level 1 — First Alarm"  IsSelected="True"/>
                                    <ComboBoxItem Content="Level 2 — Second Alarm"/>
                                    <ComboBoxItem Content="Level 3 — Third Alarm"/>
                                    <ComboBoxItem Content="Level 4 — General Alarm"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="CAUSE OF FIRE" FontFamily="Consolas" FontSize="10"
                                       Foreground="#A0B4C8" CharacterSpacing="150"/>
                            <Border Background="#1E2D3D" CornerRadius="3"
                                    BorderThickness="1" BorderBrush="#2A3F52">
                                <ComboBox x:Name="CauseBox"
                                          Background="Transparent" BorderThickness="0"
                                          Foreground="White" FontFamily="Consolas" FontSize="12"
                                          HorizontalAlignment="Stretch" Padding="10,10">
                                    <ComboBoxItem Content="Electrical"           IsSelected="True"/>
                                    <ComboBoxItem Content="Open Flame"/>
                                    <ComboBoxItem Content="LPG Leak"/>
                                    <ComboBoxItem Content="Arson"/>
                                    <ComboBoxItem Content="Faulty Wiring"/>
                                    <ComboBoxItem Content="Unattended Cooking"/>
                                    <ComboBoxItem Content="Cigarette"/>
                                    <ComboBoxItem Content="Unknown"/>
                                    <ComboBoxItem Content="Under Investigation"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="SITE PHOTO (MANDATORY)" FontFamily="Consolas" FontSize="10"
                                       Foreground="#A0B4C8" CharacterSpacing="150"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1E2D3D" CornerRadius="3"
                                        BorderThickness="1" BorderBrush="#2A3F52">
                                    <TextBox x:Name="PhotoPathBox" PlaceholderText="No photo selected"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="White" PlaceholderForeground="#4A6B8A"
                                             FontFamily="Consolas" FontSize="11" Padding="10,10"
                                             IsReadOnly="True"/>
                                </Border>
                                <Button Grid.Column="1" Content="BROWSE" Click="BrowsePhoto_Click"
                                        Background="#1E2D3D" BorderBrush="#2A3F52" BorderThickness="1"
                                        Foreground="#A0B4C8" FontFamily="Consolas" FontSize="10"
                                        Padding="12,10" CornerRadius="3"/>
                            </Grid>
                        </StackPanel>

                        <Border x:Name="FormErrorBanner" Background="#2D1A1A" CornerRadius="3"
                                Padding="12,8" Visibility="Collapsed">
                            <TextBlock x:Name="FormErrorText" Foreground="#FF6B6B"
                                       FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </Border>
                        <Border x:Name="FormSuccessBanner" Background="#1A2B1A" CornerRadius="3"
                                Padding="12,8" Visibility="Collapsed">
                            <TextBlock x:Name="FormSuccessText" Foreground="#4CAF50"
                                       FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </Border>

                        <Button x:Name="SubmitBtn" Click="Submit_Click"
                                HorizontalAlignment="Stretch" Height="48"
                                Background="#FF8070" CornerRadius="3">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B5B"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#E55A4A"/>
                            </Button.Resources>
                            <Grid HorizontalAlignment="Center">
                                <StackPanel x:Name="SubmitNormal" Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="REGISTER INCIDENT"
                                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                               Foreground="#1A1A1A" CharacterSpacing="80"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel x:Name="SubmitLoading" Orientation="Horizontal"
                                            Spacing="10" Visibility="Collapsed">
                                    <ProgressRing IsActive="True" Width="18" Height="18" Foreground="#1A1A1A"/>
                                    <TextBlock Text="SAVING..." FontFamily="Consolas" FontSize="12"
                                               FontWeight="Bold" Foreground="#1A1A1A"
                                               CharacterSpacing="80" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <HyperlinkButton Content="CLEAR FORM" HorizontalAlignment="Center"
                                         FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"
                                         Click="ClearForm_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="AnalysisPanelBorder" Background="#16202B"
                    BorderThickness="1,0,0,0" BorderBrush="#2A3F52"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1E2D3D"
                            BorderThickness="0,0,0,1" BorderBrush="#FFC107"
                            Padding="16,12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="BARANGAY ANALYSIS"
                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                       Foreground="#FFC107" CharacterSpacing="100"/>
                            <TextBlock x:Name="AnalysisBarangayName"
                                       Text="← Click a barangay polygon on the map"
                                       FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <WebView2 x:Name="ChartWebView" Grid.Row="1"/>
                </Grid>
            </Border>

            <Border x:Name="CitizenReportsPanelBorder" Background="#16202B"
                    BorderThickness="1,0,0,0" BorderBrush="#2A3F52"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1E2D3D"
                            BorderThickness="0,0,0,1" BorderBrush="#4CAF50"
                            Padding="16,12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="📞 CITIZEN REPORTS INBOX"
                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                       Foreground="#4CAF50" CharacterSpacing="100"/>
                            <TextBlock x:Name="CitizenReportsCount"
                                       Text="No reports yet"
                                       FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" Padding="12,12">
                        <StackPanel x:Name="CitizenReportsPanel" Spacing="10"/>
                    </ScrollViewer>
                </Grid>
            </Border>
            </Grid>
        </Grid>
        <Border x:Name="StatusUpdateOverlay" Grid.Row="0" Grid.RowSpan="2"
                Background="#A0000000" Visibility="Collapsed">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="#16202B" CornerRadius="8" Width="420"
                        BorderThickness="1" BorderBrush="#2A3F52">
                    <StackPanel>

                        <Border Background="#1E2D3D" CornerRadius="8,8,0,0" Padding="22,16">
                            <Grid>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="UPDATE INCIDENT STATUS"
                                               FontFamily="Consolas" FontSize="13"
                                               FontWeight="Bold" Foreground="White"
                                               CharacterSpacing="80"/>
                                    <TextBlock x:Name="StatusOverlaySubtitle"
                                               Text="Select a new status for this incident"
                                               FontFamily="Consolas" FontSize="10"
                                               Foreground="#4A6B8A"/>
                                </StackPanel>
                                <Button Content="✕" Click="CloseStatusOverlay_Click"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#4A6B8A" FontFamily="Consolas" FontSize="14"
                                        Width="32" Height="32"/>
                            </Grid>
                        </Border>

                        <StackPanel Padding="22,18" Spacing="14">

                            <StackPanel Spacing="6">
                                <TextBlock Text="INCIDENT ID" FontFamily="Consolas" FontSize="10"
                                           Foreground="#A0B4C8" CharacterSpacing="150"/>
                                <Border Background="#1E2D3D" CornerRadius="3"
                                        BorderThickness="1" BorderBrush="#2A3F52">
                                    <TextBox x:Name="StatusIncidentIdBox"
                                             PlaceholderText="—"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="#FF9B8A" PlaceholderForeground="#4A6B8A"
                                             FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                             Padding="12,10" IsReadOnly="True"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="NEW STATUS" FontFamily="Consolas" FontSize="10"
                                           Foreground="#A0B4C8" CharacterSpacing="150"/>
                                <Border Background="#1E2D3D" CornerRadius="3"
                                        BorderThickness="1" BorderBrush="#2A3F52">
                                    <ComboBox x:Name="NewStatusBox"
                                              Background="Transparent" BorderThickness="0"
                                              Foreground="White" FontFamily="Consolas" FontSize="12"
                                              HorizontalAlignment="Stretch" Padding="10,10">
                                        <ComboBoxItem Content="Active"         IsSelected="True"/>
                                        <ComboBoxItem Content="Under Control"/>
                                        <ComboBoxItem Content="Fire Out"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>

                            <Border x:Name="StatusErrorBanner" Background="#2D1A1A" CornerRadius="3"
                                    Padding="12,8" Visibility="Collapsed">
                                <TextBlock x:Name="StatusErrorText" Foreground="#FF6B6B"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                            </Border>

                            <Button Click="UpdateStatus_Click"
                                    HorizontalAlignment="Stretch" Height="46"
                                    Background="#FF8070" CornerRadius="4">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B5B"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#E55A4A"/>
                                </Button.Resources>
                                <TextBlock Text="CONFIRM STATUS UPDATE"
                                           FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                           Foreground="#1A1A1A" CharacterSpacing="60"/>
                            </Button>

                            <HyperlinkButton Content="CANCEL" HorizontalAlignment="Center"
                                             FontFamily="Consolas" FontSize="10"
                                             Foreground="#4A6B8A"
                                             Click="CloseStatusOverlay_Click"/>

                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <Border x:Name="ReportOverlay" Grid.Row="0" Grid.RowSpan="2"
                Background="#A0000000" Visibility="Collapsed">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="#16202B" CornerRadius="8" Width="580"
                        BorderThickness="1" BorderBrush="#4CAF50">
                    <StackPanel>

                        <Border Background="#1A2B1A" CornerRadius="8,8,0,0" Padding="24,18">
                            <Grid>
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="✅" FontSize="20"/>
                                        <TextBlock Text="FIRE EXTINGUISHED — INCIDENT SUMMARY"
                                                   FontFamily="Consolas" FontSize="13"
                                                   FontWeight="Bold" Foreground="#4CAF50"
                                                   CharacterSpacing="80" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ReportSubtitle"
                                               Text="Auto-generated report"
                                               FontFamily="Consolas" FontSize="10"
                                               Foreground="#4A6B8A"/>
                                </StackPanel>
                                <Button Content="✕" Click="CloseReport_Click"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#4A6B8A" FontFamily="Consolas" FontSize="14"
                                        Width="32" Height="32"/>
                            </Grid>
                        </Border>

                        <StackPanel Padding="24,20" Spacing="14">

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="INCIDENT ID" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptIncidentId" Text="—"
                                               FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                               Foreground="White"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="BARANGAY" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptBarangay" Text="—"
                                               FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                               Foreground="White"/>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="#2A3F52"/>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="SITIO / STREET" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptSitio" Text="—"
                                               FontFamily="Consolas" FontSize="13" Foreground="White"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="CAUSE OF FIRE" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptCause" Text="—"
                                               FontFamily="Consolas" FontSize="13" Foreground="White"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="ALARM LEVEL" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptAlarmLevel" Text="—"
                                               FontFamily="Consolas" FontSize="13" Foreground="#FF9B8A"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="RESPONDING OFFICER" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptOfficer" Text="—"
                                               FontFamily="Consolas" FontSize="13" Foreground="White"/>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="#2A3F52"/>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="TIME STARTED" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptTimeStarted" Text="—"
                                               FontFamily="Consolas" FontSize="13" Foreground="White"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="TIME EXTINGUISHED" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptTimeEnded" Text="—"
                                               FontFamily="Consolas" FontSize="13" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#1A2B1A" CornerRadius="6" Padding="16,12">
                                <Grid>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="TOTAL DURATION" FontFamily="Consolas"
                                                   FontSize="9" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock x:Name="RptDuration" Text="—"
                                                   FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                                                   Foreground="#4CAF50"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="DSWD STATUS" FontFamily="Consolas"
                                                   FontSize="9" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock x:Name="RptDsdwStatus" Text="—"
                                                   FontFamily="Consolas" FontSize="13"
                                                   Foreground="#FFC107" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="FAMILIES AFFECTED" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptFamilies" Text="—"
                                               FontFamily="Consolas" FontSize="13" Foreground="White"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="GPS COORDINATES" FontFamily="Consolas" FontSize="9"
                                               Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    <TextBlock x:Name="RptGps" Text="—"
                                               FontFamily="Consolas" FontSize="11" Foreground="#4A6B8A"/>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="#2A3F52"/>

                            <StackPanel Spacing="2">
                                <TextBlock Text="REPORT GENERATED" FontFamily="Consolas" FontSize="9"
                                           Foreground="#4A6B8A" CharacterSpacing="150"/>
                                <TextBlock x:Name="RptGeneratedAt" Text="—"
                                           FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                            </StackPanel>

                            <Button Click="CloseReport_Click"
                                    HorizontalAlignment="Stretch" Height="44"
                                    Background="#1A2B1A" CornerRadius="4"
                                    BorderBrush="#4CAF50" BorderThickness="1" Margin="0,4,0,0">
                                <TextBlock Text="CLOSE REPORT"
                                           FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                           Foreground="#4CAF50" CharacterSpacing="80"/>
                            </Button>

                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Page>
