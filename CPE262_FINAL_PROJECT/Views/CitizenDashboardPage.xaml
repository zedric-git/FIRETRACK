<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="CPE262_FINAL_PROJECT.Views.CitizenDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0A141E">
    <Page.Resources>
        <Style x:Key="SidebarNavStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard><ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background"><DiscreteObjectKeyFrame KeyTime="0" Value="#17202B"/></ObjectAnimationUsingKeyFrames></Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard><ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background"><DiscreteObjectKeyFrame KeyTime="0" Value="#212B35"/></ObjectAnimationUsingKeyFrames></Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalContentAlignment="Left" VerticalContentAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DatePickerDarkStyle" TargetType="DatePicker">
            <Setter Property="Background"       Value="#07111A"/>
            <Setter Property="Foreground"       Value="#D9E8F5"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="MinWidth"         Value="0"/>
        </Style>

        <SolidColorBrush x:Key="DatePickerButtonBackground"             Color="#07111A"/>
        <SolidColorBrush x:Key="DatePickerButtonBackgroundPointerOver"  Color="#0C1928"/>
        <SolidColorBrush x:Key="DatePickerButtonBackgroundPressed"      Color="#0A1520"/>
        <SolidColorBrush x:Key="DatePickerButtonBorderBrush"            Color="#142433"/>
        <SolidColorBrush x:Key="DatePickerButtonBorderBrushPointerOver" Color="#1E3347"/>
        <SolidColorBrush x:Key="DatePickerButtonBorderBrushPressed"     Color="#E63946"/>
        <SolidColorBrush x:Key="DatePickerButtonForeground"             Color="#D9E8F5"/>
        <SolidColorBrush x:Key="DatePickerButtonForegroundPointerOver"  Color="#F0F4FB"/>
        <SolidColorBrush x:Key="DatePickerFlyoutPresenterBackground"    Color="#0B1520"/>
        <SolidColorBrush x:Key="DatePickerFlyoutPresenterBorderBrush"   Color="#1E3347"/>
        <SolidColorBrush x:Key="DatePickerSpacerFill"                   Color="#142433"/>

        <Style x:Key="FilterChipStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="DetailPanelCol" Width="0"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#050F19" BorderThickness="0,0,1,0" BorderBrush="#0D1520">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="20,26,20,18" Spacing="3">
                    <TextBlock Text="FIRETRACK" FontSize="22" FontWeight="ExtraBold" FontFamily="Consolas" Foreground="#E63946" CharacterSpacing="60"/>
                    <TextBlock Text="CITIZEN PORTAL" FontSize="8" FontWeight="Bold" FontFamily="Consolas" Foreground="#334155" CharacterSpacing="300"/>
                </StackPanel>
                <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1" Fill="#0D1520"/>

                <StackPanel Grid.Row="1" Spacing="0" Margin="0,12,0,0">
                    <Grid Height="48">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Rectangle x:Name="NavFeedIndicator" Grid.Column="0" Fill="#E63946"/>
                        <Button x:Name="SidebarFeedBtn" Grid.Column="1" Style="{StaticResource SidebarNavStyle}" Background="#17202B" Click="SidebarFeed_Click">
                            <TextBlock x:Name="NavFeedText" Text="INCIDENT FEED" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#D9E3F2" CharacterSpacing="80"/>
                        </Button>
                    </Grid>
                    <Grid Height="48">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Rectangle x:Name="NavReliefIndicator" Grid.Column="0" Fill="Transparent"/>
                        <Button x:Name="SidebarReliefBtn" Grid.Column="1" Style="{StaticResource SidebarNavStyle}" Background="Transparent" Click="SidebarRelief_Click">
                            <TextBlock x:Name="NavReliefText" Text="RELIEF INFO" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#475569" CharacterSpacing="80"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Padding="12,0,12,24" Spacing="14">
                    <Button x:Name="ReportFireBtn" Click="ReportFireBtn_Click" HorizontalAlignment="Stretch" Height="42" Background="#E63946" CornerRadius="0" BorderThickness="0">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#CC2030"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#A01828"/>
                        </Button.Resources>
                        <TextBlock Text="REPORT FIRE" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="White" CharacterSpacing="200"/>
                    </Button>
                    <Rectangle Height="1" Fill="#0D1520"/>
                    <Grid>
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="OperatorName" Text="CITIZEN" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                            <TextBlock x:Name="ClockText" Text="00:00:00" FontFamily="Consolas" FontSize="9" Foreground="#334155"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Click="Logout_Click" Background="Transparent" BorderThickness="0" Padding="4">
                            <TextBlock Text="LOGOUT" FontFamily="Consolas" FontSize="9" Foreground="#334155"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Column="1">
            <Grid.Background>
                <ImageBrush ImageSource="ms-appx:///Assets/BACKROUND.png"
                            Stretch="UniformToFill"
                            Opacity="0.45"/>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Rectangle Fill="#880A141E"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Grid.RowSpan="2"/>

            <Border Grid.Row="0" Background="#0A141E" BorderThickness="0,0,0,1" BorderBrush="#0D1520">
                <Grid Padding="24,0">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderSectionTitle" Text="INCIDENT FEED" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#D9E3F2" CharacterSpacing="120"/>
                        <Border Background="#121C27" CornerRadius="0" Padding="10,4" BorderThickness="1" BorderBrush="#17202B">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="#E63946" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ActiveCountBadge" Text="0 ACTIVE" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">

                <ScrollViewer x:Name="FeedScrollView" VerticalScrollBarVisibility="Auto" Padding="24,20,24,24"
                              ViewChanged="FeedScrollView_ViewChanged">
                    <StackPanel MaxWidth="740" HorizontalAlignment="Center" Spacing="12">

                        <Border Background="#07111A" CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="#0C1E2E">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#E63946"/>
                                <Grid Grid.Column="1" Padding="14,9,12,9">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="1" Text="FROM" FontFamily="Consolas" FontSize="7.5" FontWeight="Bold" Foreground="#253848" CharacterSpacing="200" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <DatePicker x:Name="DateFromPicker" Grid.Column="2"
                                                Style="{StaticResource DatePickerDarkStyle}"
                                                SelectedDateChanged="DateFilter_Changed"
                                                HorizontalAlignment="Stretch" Margin="0,0,8,0"/>

                                    <TextBlock Grid.Column="5" Text="TO" FontFamily="Consolas" FontSize="7.5" FontWeight="Bold" Foreground="#253848" CharacterSpacing="200" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <DatePicker x:Name="DateToPicker" Grid.Column="6"
                                                Style="{StaticResource DatePickerDarkStyle}"
                                                SelectedDateChanged="DateFilter_Changed"
                                                HorizontalAlignment="Stretch" Margin="0,0,10,0"/>

                                    <Button x:Name="ClearDateBtn" Grid.Column="7" Click="ClearDate_Click"
                                            Background="Transparent" BorderThickness="1" BorderBrush="#142433"
                                            CornerRadius="0" Padding="10,6,10,6" VerticalAlignment="Center">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0C1928"/>
                                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#1E3347"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#4F6C8A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="FilterBarGrid" Orientation="Horizontal" Spacing="7" Margin="0,0,0,2">
                            <Button x:Name="ActiveFilterBtn" Style="{StaticResource FilterChipStyle}" Background="#0B1520" BorderBrush="#142433" Click="FilterPill_Click" Tag="Active">
                                <TextBlock x:Name="ActiveFilterText" Text="ACTIVE" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="#4F6C8A" CharacterSpacing="150"/>
                            </Button>
                            <Button x:Name="UnderControlFilterBtn" Style="{StaticResource FilterChipStyle}" Background="#0B1520" BorderBrush="#142433" Click="FilterPill_Click" Tag="Under Control">
                                <TextBlock x:Name="UnderControlFilterText" Text="UNDER CONTROL" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="#4F6C8A" CharacterSpacing="150"/>
                            </Button>
                            <Button x:Name="FireOutFilterBtn" Style="{StaticResource FilterChipStyle}" Background="#0B1520" BorderBrush="#142433" Click="FilterPill_Click" Tag="Fire Out">
                                <TextBlock x:Name="FireOutFilterText" Text="FIRE OUT" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="#4F6C8A" CharacterSpacing="150"/>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="IncidentFeedPanel" Spacing="14"/>
                    </StackPanel>
                </ScrollViewer>

                <Button x:Name="FeedBackToTopBtn"
                        Click="FeedBackToTop_Click"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,28,28"
                        Background="#E63946"
                        BorderThickness="0"
                        CornerRadius="0"
                        Padding="14,10,14,10">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#CC2030"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#A01828"/>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="TOP" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="White" CharacterSpacing="160" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <ScrollViewer x:Name="ReliefScrollView" VerticalScrollBarVisibility="Auto" Padding="24,20,24,24" Visibility="Collapsed">
                    <StackPanel MaxWidth="620" HorizontalAlignment="Center" Spacing="14">

                        <Border CornerRadius="0" BorderThickness="0,3,0,0" BorderBrush="#F59E0B" Background="#0B1520" Padding="18,14,18,14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="RELIEF DISTRIBUTION TRANSPARENCY" FontFamily="Consolas" FontSize="16" FontWeight="ExtraBold" Foreground="#F59E0B" CharacterSpacing="200"/>
                                <TextBlock x:Name="ReliefHeaderSubtext" Text="View official relief records for fire incidents in your area." FontFamily="Consolas" FontSize="10" Foreground="#4F6C8A" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ReliefGatePanel" Background="#0B1520" CornerRadius="0" BorderThickness="1" BorderBrush="#142433" Padding="28,40,28,40">
                            <StackPanel Spacing="28" HorizontalAlignment="Center">
                                <TextBlock Text="WERE YOU AFFECTED BY A FIRE INCIDENT IN YOUR BARANGAY?" FontFamily="Consolas" FontSize="13.5" FontWeight="Bold" Foreground="#D9E8F5" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                                    <Button x:Name="YesAffectedBtn" Click="YesAffected_Click" Height="48" MinWidth="190" Background="#071A18" BorderThickness="1" BorderBrush="#14B8A6" CornerRadius="0">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0A2420"/>
                                        </Button.Resources>
                                        <TextBlock Text="YES, I WAS AFFECTED" FontFamily="Consolas" FontSize="10.5" FontWeight="Bold" Foreground="#14B8A6" CharacterSpacing="150"/>
                                    </Button>
                                    <Button x:Name="NoBrowsingBtn" Click="NoBrowsing_Click" Height="48" MinWidth="190" Background="Transparent" BorderThickness="1" BorderBrush="#142433" CornerRadius="0">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0F1C2A"/>
                                        </Button.Resources>
                                        <TextBlock Text="NO — JUST BROWSING" FontFamily="Consolas" FontSize="10.5" FontWeight="Bold" Foreground="#4F6C8A" CharacterSpacing="150"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ReliefNoPanel" Visibility="Collapsed" Background="#0B1520" CornerRadius="0" BorderThickness="1" BorderBrush="#142433" Padding="20">
                            <StackPanel x:Name="ReliefNoContent" Spacing="14"/>
                        </Border>

                        <StackPanel x:Name="ReliefFormPanel" Visibility="Collapsed" Spacing="14">
                            <Border Background="#0B1520" CornerRadius="0" BorderThickness="1" BorderBrush="#142433" Padding="22,20,22,20">
                                <StackPanel Spacing="18">
                                    <TextBlock Text="HOUSEHOLD RELIEF LOOKUP" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#F59E0B" CharacterSpacing="200"/>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="SELECT YOUR ASSIGNED EVACUATION CENTER" FontFamily="Consolas" FontSize="8.5" FontWeight="SemiBold" Foreground="#253848" CharacterSpacing="200"/>
                                        <ComboBox x:Name="ReliefEvacCombo" HorizontalAlignment="Stretch" Background="#07111A" Foreground="#D9E8F5" FontFamily="Consolas" FontSize="11" Padding="10,10" PlaceholderText="Select evacuation center…"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="HEAD OF HOUSEHOLD FULL NAME" FontFamily="Consolas" FontSize="8.5" FontWeight="SemiBold" Foreground="#253848" CharacterSpacing="200"/>
                                        <Border Background="#07111A" CornerRadius="0" BorderThickness="1" BorderBrush="#142433">
                                            <TextBox x:Name="ReliefHeadNameBox" PlaceholderText="Enter full name exactly as registered" Background="Transparent" BorderThickness="0" Foreground="#D9E8F5" PlaceholderForeground="#253848" FontFamily="Consolas" FontSize="11" Padding="14,12,14,12" MaxLength="200"/>
                                        </Border>
                                        <TextBlock Text="Name must match exactly as registered by your barangay (case-sensitive)." FontFamily="Consolas" FontSize="8.5" Foreground="#253848" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Border x:Name="ReliefLookupErrorPanel" Background="#2A0D10" CornerRadius="0" Padding="14,10,14,10" Visibility="Collapsed" BorderThickness="1" BorderBrush="#7A2020">
                                        <TextBlock x:Name="ReliefLookupErrorText" Foreground="#FF8080" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
                                    </Border>

                                    <Button x:Name="ReliefLookupBtn" Click="ReliefLookup_Click" HorizontalAlignment="Stretch" Height="46" Background="#E63946" CornerRadius="0" BorderThickness="0">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C0242F"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#A01828"/>
                                        </Button.Resources>
                                        <TextBlock Text="LOOK UP MY RELIEF STATUS" FontFamily="Consolas" FontSize="10.5" FontWeight="Bold" Foreground="White" CharacterSpacing="200"/>
                                    </Button>

                                    <Button Click="BackToGate_Click" Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Center">
                                        <TextBlock Text="← BACK TO GATE" FontFamily="Consolas" FontSize="9" Foreground="#253848" CharacterSpacing="150"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="ReliefResultPanel" Visibility="Collapsed" Spacing="14">
                            <StackPanel x:Name="ReliefResultContent" Spacing="14"/>
                            <Button x:Name="ReliefDSWDBtn" Click="ReliefDSWD_Click" HorizontalAlignment="Stretch" Height="46" Background="#071A18" CornerRadius="0" BorderThickness="1" BorderBrush="#14B8A6" Visibility="Collapsed">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0A2420"/>
                                </Button.Resources>
                                <TextBlock Text="MESSAGE DSWD" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="#14B8A6" CharacterSpacing="200"/>
                            </Button>
                            <Button Click="BackToForm_Click" Background="Transparent" BorderThickness="1" BorderBrush="#142433" CornerRadius="0" Padding="16,10,16,10" HorizontalAlignment="Center">
                                <TextBlock Text="LOOK UP A DIFFERENT HOUSEHOLD" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="#4F6C8A" CharacterSpacing="100"/>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
        <Border Grid.Column="2" x:Name="DetailPanel" Background="#0C1822" BorderThickness="1,0,0,0" BorderBrush="#0D1520">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="280"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" x:Name="DetailImageHeader" Background="#121C27">
                    <Grid>
                        <Image x:Name="DetailHeaderImage" Stretch="UniformToFill" Opacity="0.55" Visibility="Collapsed"/>
                        <Border x:Name="DetailColorBg" Opacity="0.4" Background="#E63946"/>
                        <Border VerticalAlignment="Stretch">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0.3"/>
                                    <GradientStop Color="#0C1822" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="16,0,0,16">
                            <Border x:Name="DetailAlarmBadge" Background="#E63946" CornerRadius="0" Padding="8,4">
                                <TextBlock x:Name="DetailAlarmText" Text="ALARM 1" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <Border x:Name="DetailStatusBadgeBorder" Background="#E63946" CornerRadius="0" Padding="10,4">
                                <TextBlock x:Name="DetailStatusBadgeText" Text="ACTIVE" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <Button x:Name="CloseDetailBtn" Click="CloseDetail_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0" Background="#1A2535" BorderThickness="0" Padding="8,6" CornerRadius="0">
                            <Button.Resources><SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#243040"/></Button.Resources>
                            <TextBlock Text="CLOSE" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#94A3B8"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="18,10,18,10" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <StackPanel x:Name="DetailContent" Spacing="14" Padding="0,4,0,4"/>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <WebView2 x:Name="DetailMapWebView"/>
                    <Border x:Name="DetailMapLoading" Background="#09131C">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                            <ProgressRing IsActive="True" Width="24" Height="24" Foreground="#E63946"/>
                            <TextBlock Text="LOADING MAP" FontFamily="Consolas" FontSize="9" Foreground="#334155" CharacterSpacing="200" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Padding="14,10,14,14" Background="#04090F" BorderThickness="0,1,0,0" BorderBrush="#0C1E2E">
                    <Grid>
                        <Button x:Name="DetailDSWDBtn" Width="0" Height="0" Visibility="Collapsed"/>
                        <TextBlock Text="- INCIDENT MAP -" FontFamily="Consolas" FontSize="8.5" Foreground="#253848" CharacterSpacing="150" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <Border x:Name="ReportFireOverlay" Grid.ColumnSpan="3" Background="#CC000000" Visibility="Collapsed">
            <ScrollViewer VerticalScrollMode="Auto" HorizontalScrollMode="Disabled">
                <Border Width="480" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,32,0,32" Background="#121C27" CornerRadius="0" BorderThickness="0,2,0,0" BorderBrush="#E63946" Padding="28">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Border Background="#2D1014" CornerRadius="0" Padding="10,5" HorizontalAlignment="Left">
                                <TextBlock Text="REPORT FIRE INCIDENT" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#E63946" CharacterSpacing="100"/>
                            </Border>
                            <Button x:Name="CloseReportBtn" Click="CloseReportBtn_Click" HorizontalAlignment="Right" Background="Transparent" BorderThickness="1" BorderBrush="#1E2D3D" Padding="10,5" CornerRadius="0">
                                <TextBlock Text="CLOSE" FontFamily="Consolas" FontSize="9" Foreground="#475569"/>
                            </Button>
                        </Grid>
                        <Rectangle Height="1" Fill="#1A2535"/>
                        <Border Background="#0A141E" CornerRadius="0" Padding="16,14" BorderThickness="1" BorderBrush="#17202B">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <TextBlock Text="REPORTER NAME" FontFamily="Consolas" FontSize="9" Foreground="#334155" CharacterSpacing="120" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ReporterNameText" HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11" Foreground="#D9E3F2" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#17202B"/>
                                <Grid>
                                    <TextBlock Text="MOBILE NUMBER" FontFamily="Consolas" FontSize="9" Foreground="#334155" CharacterSpacing="120" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ReporterPhoneText" HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11" Foreground="#D9E3F2" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <StackPanel Spacing="6">
                            <TextBlock Text="INCIDENT ADDRESS / LANDMARK" FontFamily="Consolas" FontSize="9" Foreground="#334155" CharacterSpacing="120"/>
                            <Border Background="#0A141E" CornerRadius="0" BorderThickness="1" BorderBrush="#17202B">
                                <TextBox x:Name="ReportAddressBox" PlaceholderText="e.g. Near the market, Sitio Lawis" Background="Transparent" BorderThickness="0" Foreground="#D9E3F2" PlaceholderForeground="#1E2D3D" FontFamily="Consolas" FontSize="12" Padding="14,12" MaxLength="300"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="BARANGAY" FontFamily="Consolas" FontSize="9" Foreground="#334155" CharacterSpacing="120"/>
                            <ComboBox x:Name="ReportBarangayCombo" PlaceholderText="Select barangay" HorizontalAlignment="Stretch" Background="#0A141E" Foreground="#D9E3F2" FontFamily="Consolas" FontSize="12" Padding="10,10"/>
                        </StackPanel>
                        <Border x:Name="ReportErrorBanner" Background="#2D1014" CornerRadius="0" Padding="14,10" Visibility="Collapsed" BorderThickness="1" BorderBrush="#7A2020">
                            <TextBlock x:Name="ReportErrorText" Foreground="#FF8080" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
                        </Border>
                        <Border x:Name="ReportSuccessBanner" Background="#0D2A18" CornerRadius="0" Padding="14,10" Visibility="Collapsed" BorderThickness="1" BorderBrush="#2A6A40">
                            <TextBlock x:Name="ReportSuccessText" Foreground="#80D8A0" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
                        </Border>
                        <Button x:Name="SubmitReportBtn" Click="SubmitReportBtn_Click" HorizontalAlignment="Stretch" Height="46" Background="#E63946" CornerRadius="0" BorderThickness="0">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#CC2030"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#A01828"/>
                            </Button.Resources>
                            <Grid HorizontalAlignment="Center">
                                <StackPanel x:Name="SubmitNormalState" Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="SUBMIT FIRE REPORT" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="White" CharacterSpacing="120" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel x:Name="SubmitLoadingState" Orientation="Horizontal" Spacing="10" Visibility="Collapsed">
                                    <ProgressRing IsActive="True" Width="16" Height="16" Foreground="White"/>
                                    <TextBlock Text="SUBMITTING..." FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="White" CharacterSpacing="120" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Border>
        <Border x:Name="DSWDOverlay" Grid.ColumnSpan="3" Background="#CC000000" Visibility="Collapsed">
            <ScrollViewer VerticalScrollMode="Auto" HorizontalScrollMode="Disabled">
                <Border Width="480" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,32,0,32"
                        Background="#0A1623" CornerRadius="0" BorderThickness="0,3,0,0" BorderBrush="#14B8A6" Padding="24">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Border Background="#071A18" CornerRadius="0" Padding="10,5" HorizontalAlignment="Left">
                                <TextBlock Text="MESSAGE TO DSWD" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#14B8A6" CharacterSpacing="100"/>
                            </Border>
                            <Button x:Name="CloseDSWDBtn" Click="CloseDSWDBtn_Click" HorizontalAlignment="Right"
                                    Background="Transparent" BorderThickness="1" BorderBrush="#142433" Padding="10,5" CornerRadius="0">
                                <TextBlock Text="CLOSE" FontFamily="Consolas" FontSize="9" Foreground="#4F6C8A"/>
                            </Button>
                        </Grid>
                        <Rectangle Height="1" Fill="#142433"/>
                        <Border Background="#07111A" CornerRadius="0" Padding="14,12,14,12" BorderThickness="1" BorderBrush="#0C1E2E">
                            <TextBlock x:Name="DSWDContextText" FontFamily="Consolas" FontSize="10" Foreground="#4F6C8A" TextWrapping="Wrap"/>
                        </Border>
                        <StackPanel Spacing="6">
                            <TextBlock Text="YOUR MESSAGE" FontFamily="Consolas" FontSize="8.5" FontWeight="SemiBold" Foreground="#253848" CharacterSpacing="200"/>
                            <Border Background="#07111A" CornerRadius="0" BorderThickness="1" BorderBrush="#142433">
                                <TextBox x:Name="DSWDMessageBox"
                                         PlaceholderText="Describe what you need DSWD to know about this incident…"
                                         AcceptsReturn="True" TextWrapping="Wrap" Height="110"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#D9E8F5" PlaceholderForeground="#253848"
                                         FontFamily="Consolas" FontSize="11" Padding="14,12,14,12" MaxLength="1000"/>
                            </Border>
                        </StackPanel>
                        <Border x:Name="DSWDErrorBanner" Background="#2A0D10" CornerRadius="0"
                                Padding="14,10,14,10" Visibility="Collapsed" BorderThickness="1" BorderBrush="#7A2020">
                            <TextBlock x:Name="DSWDErrorText" Foreground="#FF8080" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
                        </Border>
                        <Border x:Name="DSWDSuccessBanner" Background="#071A18" CornerRadius="0"
                                Padding="14,10,14,10" Visibility="Collapsed" BorderThickness="1" BorderBrush="#14B8A6">
                            <TextBlock x:Name="DSWDSuccessText" Foreground="#14B8A6" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
                        </Border>
                        <Button x:Name="DSWDSendBtn" Click="DSWDSendBtn_Click" HorizontalAlignment="Stretch"
                                Height="46" Background="#071A18" CornerRadius="0" BorderThickness="1" BorderBrush="#14B8A6">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0A2420"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#05120E"/>
                            </Button.Resources>
                            <Grid HorizontalAlignment="Center">
                                <StackPanel x:Name="DSWDSendNormalState" Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="SEND MESSAGE" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="#14B8A6" CharacterSpacing="150" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel x:Name="DSWDSendLoadingState" Orientation="Horizontal" Spacing="10" Visibility="Collapsed">
                                    <ProgressRing IsActive="True" Width="16" Height="16" Foreground="#14B8A6"/>
                                    <TextBlock Text="SENDING..." FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="#14B8A6" CharacterSpacing="150" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
