<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPE262_FINAL_PROJECT.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D1B2A">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="ms-appx:///Assets/BACKROUND.png"
                        Stretch="UniformToFill"
                        Opacity="0.45"/>
        </Grid.Background>
        <Rectangle Fill="#880D1B2A"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>

        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20,16,0,0" Spacing="2">
            <TextBlock Text="FIRETRACK // CITIZEN REGISTRATION" Foreground="#4A6B8A" FontSize="11" FontFamily="Consolas"/>
            <TextBlock Text="REGION VII — CEBU CITY"            Foreground="#4A6B8A" FontSize="11" FontFamily="Consolas"/>
        </StackPanel>

        <Border Width="400" Height="750" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#16202B" CornerRadius="4"
                BorderThickness="0,3,0,0" BorderBrush="#FF7B6B"
                Padding="40,30,40, 0.1">
            <StackPanel Spacing="0">

                <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="FIRETRACK" FontSize="22" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="White"
                                   VerticalAlignment="Center" CharacterSpacing="150"/>
                    </StackPanel>
                    <TextBlock Text="CITIZEN PORTAL REGISTRATION" FontSize="11" FontFamily="Consolas"
                               Foreground="#FF9B8A" HorizontalAlignment="Center" CharacterSpacing="200"/>
                </StackPanel>

                <Border Background="#1E3A2A" CornerRadius="3" Padding="12,8" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#4CAF50" VerticalAlignment="Center"/>
                        <TextBlock Text="ROLE: CITIZEN — PUBLIC TRANSPARENCY PORTAL"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#4CAF50" CharacterSpacing="80"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="FULL NAME" FontSize="11" FontFamily="Consolas"
                           Foreground="#A0B4C8" CharacterSpacing="150" Margin="0,0,0,8"/>
                <Border x:Name="NameBorder" Background="#1E2D3D" CornerRadius="3"
                        BorderThickness="1" BorderBrush="#2A3F52" Margin="0,0,0,16">
                    <TextBox x:Name="NameBox"
                             Text="{x:Bind ViewModel.FullName, Mode=TwoWay}"
                             PlaceholderText="Enter your full legal name"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" PlaceholderForeground="#4A6B8A"
                             FontFamily="Consolas" FontSize="13" Padding="14,12"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="{Binding ElementName=NameBorder}"/>
                </Border>

                <TextBlock Text="MOBILE NUMBER" FontSize="11" FontFamily="Consolas"
                           Foreground="#A0B4C8" CharacterSpacing="150" Margin="0,0,0,8"/>
                <Border x:Name="PhoneBorder" Background="#1E2D3D" CornerRadius="3"
                        BorderThickness="1" BorderBrush="#2A3F52" Margin="0,0,0,16">
                    <TextBox x:Name="PhoneBox"
                             Text="{x:Bind ViewModel.PhoneNumber, Mode=TwoWay}"
                             PlaceholderText="09171234567 or +639171234567"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" PlaceholderForeground="#4A6B8A"
                             FontFamily="Consolas" FontSize="13" Padding="14,12"
                             InputScope="TelephoneNumber" MaxLength="15"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="{Binding ElementName=PhoneBorder}"/>
                </Border>

                <TextBlock Text="HOME BARANGAY" FontSize="11" FontFamily="Consolas"
                           Foreground="#A0B4C8" CharacterSpacing="150" Margin="0,0,0,4"/>
                <Border x:Name="BarangayBorder" Background="#1E2D3D" CornerRadius="3"
                        BorderThickness="1" BorderBrush="#2A3F52" Margin="0,0,0,16">
                    <ComboBox x:Name="BarangayCombo"
                              PlaceholderText="Select your barangay"
                              HorizontalAlignment="Stretch"
                              Background="Transparent" BorderThickness="0"
                              Foreground="White"
                              FontFamily="Consolas" FontSize="13" Padding="10,10"
                              SelectionChanged="BarangayCombo_SelectionChanged"/>
                </Border>

                <TextBlock Text="EMAIL ADDRESS" FontSize="11" FontFamily="Consolas"
                           Foreground="#A0B4C8" CharacterSpacing="150" Margin="0,0,0,8"/>
                <Border x:Name="EmailBorder" Background="#1E2D3D" CornerRadius="3"
                        BorderThickness="1" BorderBrush="#2A3F52" Margin="0,0,0,16">
                    <TextBox x:Name="EmailBox"
                             Text="{x:Bind ViewModel.Email, Mode=TwoWay}"
                             PlaceholderText="your@email.com"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" PlaceholderForeground="#4A6B8A"
                             FontFamily="Consolas" FontSize="13" Padding="14,12"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="{Binding ElementName=EmailBorder}"/>
                </Border>

                <TextBlock Text="PASSWORD" FontSize="11" FontFamily="Consolas"
                           Foreground="#A0B4C8" CharacterSpacing="150" Margin="0,0,0,8"/>
                <Border x:Name="PasswordBorder" Background="#1E2D3D" CornerRadius="3"
                        BorderThickness="1" BorderBrush="#2A3F52" Margin="0,0,0,16">
                    <PasswordBox x:Name="PasswordBox"
                                 PlaceholderText="Min. 6 characters"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" FontFamily="Consolas" FontSize="13"
                                 Padding="14,12" PasswordRevealMode="Hidden"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocus"/>
                </Border>

                <TextBlock Text="CONFIRM PASSWORD" FontSize="11" FontFamily="Consolas"
                           Foreground="#A0B4C8" CharacterSpacing="150" Margin="0,0,0,8"/>
                <Border x:Name="ConfirmBorder" Background="#1E2D3D" CornerRadius="3"
                        BorderThickness="1" BorderBrush="#2A3F52" Margin="0,0,0,16">
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 PlaceholderText="Re-enter your password"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" FontFamily="Consolas" FontSize="13"
                                 Padding="14,12" PasswordRevealMode="Hidden"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                                 GotFocus="ConfirmBox_GotFocus" LostFocus="ConfirmBox_LostFocus"/>
                </Border>

                <Border x:Name="ErrorBanner" Background="#2D1A1A" CornerRadius="3"
                        Padding="12,8" Margin="0,0,0,14" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#FF6B6B"
                               FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <Button x:Name="RegisterBtn" Command="{x:Bind ViewModel.RegisterCommand}"
                        HorizontalAlignment="Stretch" Height="52"
                        Background="#FF8070" CornerRadius="3" Margin="0,0,0,16">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B5B"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#E55A4A"/>
                    </Button.Resources>
                    <Grid HorizontalAlignment="Center">
                        <StackPanel x:Name="NormalState" Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="CREATE CITIZEN ACCOUNT"
                                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="#1A1A1A" CharacterSpacing="100" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="LoadingState" Orientation="Horizontal"
                                    Spacing="10" Visibility="Collapsed">
                            <ProgressRing IsActive="True" Width="18" Height="18" Foreground="#1A1A1A"/>
                            <TextBlock Text="PROCESSING..."
                                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="#1A1A1A" CharacterSpacing="100" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <HyperlinkButton Content="← BACK TO LOGIN"
                                 HorizontalAlignment="Center"
                                 FontFamily="Consolas" FontSize="11" Foreground="#FF9B8A"
                                 Click="BackToLoginBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
