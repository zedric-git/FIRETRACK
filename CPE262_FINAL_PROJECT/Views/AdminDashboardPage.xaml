<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPE262_FINAL_PROJECT.Views.AdminDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CPE262_FINAL_PROJECT.Models"
    xmlns:converters="using:CPE262_FINAL_PROJECT.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D1B2A">

    <Page.Resources>
        <converters:BoolToColorConverter       x:Key="BoolToColorConverter"/>
        <converters:BoolToDisableTextConverter x:Key="BoolToDisableTextConverter"/>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#16202B" BorderThickness="0,0,0,1" BorderBrush="#2A3F52">
            <Grid Padding="20,0">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="FIRETRACK" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas" Foreground="White" CharacterSpacing="150" VerticalAlignment="Center"/>
                    <Border Background="#FF8070" CornerRadius="3" Padding="8,2">
                        <TextBlock Text="ADMIN" FontFamily="Consolas" FontSize="10"
                                   Foreground="#1A1A1A" FontWeight="Bold" CharacterSpacing="150"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="ClockText" FontFamily="Consolas" FontSize="11" Foreground="#4A6B8A"/>
                    <TextBlock Text="|" Foreground="#2A3F52"/>
                    <TextBlock Text="{x:Bind ViewModel.OperatorName, Mode=OneWay}"
                               FontFamily="Consolas" FontSize="11" Foreground="#A0B4C8"/>
                    <Button Content="LOGOUT" Click="Logout_Click"
                            Background="Transparent" BorderBrush="#FF8070" BorderThickness="1"
                            Foreground="#FF8070" FontFamily="Consolas" FontSize="10"
                            Padding="10,4" CornerRadius="3"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24,20" x:Name="MainScroll">
            <StackPanel Spacing="24">

                <TextBlock Text="SYSTEM OVERVIEW" FontFamily="Consolas" FontSize="11"
                           Foreground="#4A6B8A" CharacterSpacing="200"/>
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#16202B" CornerRadius="4" BorderThickness="0,3,0,0" BorderBrush="#FF8070" Padding="20,16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="TOTAL OPERATORS"   FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalUsers, Mode=OneWay}"    FontFamily="Consolas" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="registered accounts" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#16202B" CornerRadius="4" BorderThickness="0,3,0,0" BorderBrush="#4CAF50" Padding="20,16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="ACTIVE ACCOUNTS"   FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                            <TextBlock Text="{x:Bind ViewModel.ActiveUsers, Mode=OneWay}"   FontFamily="Consolas" FontSize="36" FontWeight="Bold" Foreground="#4CAF50"/>
                            <TextBlock Text="can log in"         FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#16202B" CornerRadius="4" BorderThickness="0,3,0,0" BorderBrush="#FF5252" Padding="20,16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="DISABLED ACCOUNTS" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                            <TextBlock Text="{x:Bind ViewModel.DisabledUsers, Mode=OneWay}" FontFamily="Consolas" FontSize="36" FontWeight="Bold" Foreground="#FF5252"/>
                            <TextBlock Text="access revoked"     FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="#16202B" CornerRadius="4" BorderThickness="0,3,0,0" BorderBrush="#64B5F6" Padding="20,16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="AUDIT EVENTS TODAY" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                            <TextBlock Text="{x:Bind ViewModel.TodayAuditCount, Mode=OneWay}" FontFamily="Consolas" FontSize="36" FontWeight="Bold" Foreground="#64B5F6"/>
                            <TextBlock Text="actions logged"      FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="#16202B" CornerRadius="4" Padding="20">
                    <StackPanel Spacing="16">
                        <Grid>
                            <TextBlock Text="USER MANAGEMENT" FontFamily="Consolas" FontSize="13"
                                       FontWeight="Bold" Foreground="White" CharacterSpacing="150" VerticalAlignment="Center"/>
                            <Button Content="+ CREATE NEW OPERATOR" Click="CreateUser_Click"
                                    HorizontalAlignment="Right" Background="#FF8070" CornerRadius="3"
                                    Foreground="#1A1A1A" FontFamily="Consolas" FontSize="11"
                                    FontWeight="Bold" Padding="14,8">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B5B"/>
                                </Button.Resources>
                            </Button>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     x:Name="UserSearchBox"
                                     PlaceholderText="Search by name, email or barangay..."
                                     Background="#1E2D3D" BorderThickness="1" BorderBrush="#2A3F52"
                                     Foreground="White" PlaceholderForeground="#4A6B8A"
                                     FontFamily="Consolas" FontSize="12" Padding="12,10"
                                     TextChanged="UserSearch_TextChanged"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind ViewModel.RoleFilters}"
                                      SelectedItem="{x:Bind ViewModel.SelectedRoleFilter, Mode=TwoWay}"
                                      Background="#1E2D3D" BorderBrush="#2A3F52"
                                      Foreground="White" FontFamily="Consolas" FontSize="12"
                                      HorizontalAlignment="Stretch" Padding="12,10"/>
                        </Grid>

                        <Border BorderThickness="1" BorderBrush="#2A3F52" CornerRadius="3">
                            <StackPanel>
                                <Border Background="#1E2D3D" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="515"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ID"        FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="1" Text="FULL NAME" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="2" Text="EMAIL"     FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="3" Text="ROLE"      FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="4" Text="BARANGAY"  FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="5" Text="STATUS"    FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="6" Text="ACTIONS"   FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.FilteredUsers, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:User">
                                            <Border BorderThickness="0,1,0,0" BorderBrush="#1E2D3D" Padding="12,11">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36"/>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="530"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind UserID}"
                                                               FontFamily="Consolas" FontSize="12" Foreground="#4A6B8A" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind FullName}"
                                                               FontFamily="Consolas" FontSize="12" Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="2" Text="{x:Bind Email}"
                                                               FontFamily="Consolas" FontSize="11" Foreground="#A0B4C8" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    <Border Grid.Column="3" CornerRadius="3" Background="#1E2D3D"
                                                            Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Role}" FontFamily="Consolas" FontSize="10" Foreground="#FF9B8A" CharacterSpacing="80"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="4" Text="{x:Bind AssignedBarangay}"
                                                               FontFamily="Consolas" FontSize="11" Foreground="#A0B4C8" VerticalAlignment="Center"/>
                                                    <Ellipse Grid.Column="5" Width="10" Height="10"
                                                             HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="{x:Bind IsActive, Converter={StaticResource BoolToColorConverter}}"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Button Content="EDIT" Tag="{x:Bind}" Click="EditUser_Click"
                                                                Background="#1E2D3D" BorderBrush="#2A3F52" BorderThickness="1"
                                                                Foreground="#64B5F6" FontFamily="Consolas" FontSize="10" Padding="8,4" CornerRadius="3"/>
                                                        <Button Tag="{x:Bind}"
                                                                Content="{x:Bind IsActive, Converter={StaticResource BoolToDisableTextConverter}}"
                                                                Click="ToggleActive_Click"
                                                                Background="#1E2D3D" BorderBrush="#2A3F52" BorderThickness="1"
                                                                Foreground="#FF9B8A" FontFamily="Consolas" FontSize="10" Padding="8,4" CornerRadius="3"/>
                                                        <Button Content="RESET PWD" Tag="{x:Bind}" Click="ResetPassword_Click"
                                                                Background="#1E2D3D" BorderBrush="#2A3F52" BorderThickness="1"
                                                                Foreground="#A0B4C8" FontFamily="Consolas" FontSize="10" Padding="8,4" CornerRadius="3"/>
                                                        <Button Content="DELETE" Tag="{x:Bind}" Click="DeleteUser_Click"
                                                                Background="#2D1A1A" BorderBrush="#FF5252" BorderThickness="1"
                                                                Foreground="#FF5252" FontFamily="Consolas" FontSize="10" Padding="8,4" CornerRadius="3"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="#16202B" CornerRadius="4" Padding="20">
                    <StackPanel Spacing="16">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="AUDIT TRAIL" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="White" CharacterSpacing="150"/>
                                <TextBlock Text="READ-ONLY — No edits or deletions permitted" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                            </StackPanel>
                            <Button Content="REFRESH" Click="RefreshLogs_Click" HorizontalAlignment="Right"
                                    Background="#1E2D3D" BorderBrush="#2A3F52" BorderThickness="1"
                                    Foreground="#A0B4C8" FontFamily="Consolas" FontSize="10" Padding="12,6" CornerRadius="3"/>
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     x:Name="LogSearchBox"
                                     PlaceholderText="Search logs..."
                                     Background="#1E2D3D" BorderThickness="1" BorderBrush="#2A3F52"
                                     Foreground="White" PlaceholderForeground="#4A6B8A"
                                     FontFamily="Consolas" FontSize="12" Padding="12,10"
                                     TextChanged="LogSearch_TextChanged"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind ViewModel.ActionFilters}"
                                      SelectedItem="{x:Bind ViewModel.LogActionFilter, Mode=TwoWay}"
                                      Background="#1E2D3D" BorderBrush="#2A3F52"
                                      Foreground="White" FontFamily="Consolas" FontSize="12"
                                      HorizontalAlignment="Stretch" Padding="12,10"/>
                        </Grid>
                        <Border BorderThickness="1" BorderBrush="#2A3F52" CornerRadius="3">
                            <StackPanel>
                                <Border Background="#1E2D3D" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="LOG ID"    FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="1" Text="USER ID"   FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="2" Text="ACTION"    FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="3" Text="TABLE"     FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="4" Text="REASON"    FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Grid.Column="5" Text="TIMESTAMP" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                    </Grid>
                                </Border>
                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.FilteredLogs, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:AuditLog">
                                                <Border BorderThickness="0,1,0,0" BorderBrush="#1E2D3D" Padding="12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="160"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{x:Bind LogID}"       FontFamily="Consolas" FontSize="11" Foreground="#4A6B8A"/>
                                                        <TextBlock Grid.Column="1" Text="{x:Bind UserID}"      FontFamily="Consolas" FontSize="11" Foreground="#A0B4C8"/>
                                                        <Border Grid.Column="2" CornerRadius="3" Background="#1A2B1A" Padding="6,2" HorizontalAlignment="Left">
                                                            <TextBlock Text="{x:Bind Action}" FontFamily="Consolas" FontSize="10" Foreground="#4CAF50" CharacterSpacing="80"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="3" Text="{x:Bind TargetTable}" FontFamily="Consolas" FontSize="11" Foreground="#A0B4C8"/>
                                                        <TextBlock Grid.Column="4" Text="{x:Bind Reason}"      FontFamily="Consolas" FontSize="11" Foreground="White" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="5" Text="{x:Bind Timestamp}"   FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="#16202B" CornerRadius="4" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="SYSTEM PANEL" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="White" CharacterSpacing="150"/>
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#1E2D3D" CornerRadius="4" BorderThickness="1" BorderBrush="#2A3F52" Padding="20,16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="DATABASE BACKUP" FontFamily="Consolas" FontSize="11" Foreground="#A0B4C8" CharacterSpacing="150"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Last backup:" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A"/>
                                        <TextBlock Text="{x:Bind ViewModel.LastBackupTime, Mode=OneWay}" FontFamily="Consolas" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind ViewModel.BackupStatus, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="#4CAF50" TextWrapping="Wrap"/>
                                    <Button Click="Backup_Click" HorizontalAlignment="Left"
                                            Background="#FF8070" CornerRadius="3"
                                            Foreground="#1A1A1A" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Padding="16,10">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B5B"/>
                                        </Button.Resources>
                                        <TextBlock Text="BACKUP DATABASE NOW" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#1A1A2A" CornerRadius="4" BorderThickness="1" BorderBrush="#FF5252" Padding="20,16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="ADMIN SCOPE RESTRICTION" FontFamily="Consolas" FontSize="11" Foreground="#FF5252" CharacterSpacing="100"/>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="PERMITTED:" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Text="✓  User account management" FontFamily="Consolas" FontSize="11" Foreground="#4CAF50"/>
                                        <TextBlock Text="✓  Role assignment"         FontFamily="Consolas" FontSize="11" Foreground="#4CAF50"/>
                                        <TextBlock Text="✓  Audit log review"        FontFamily="Consolas" FontSize="11" Foreground="#4CAF50"/>
                                        <TextBlock Text="✓  Database backup"         FontFamily="Consolas" FontSize="11" Foreground="#4CAF50"/>
                                    </StackPanel>
                                    <Rectangle Height="1" Fill="#2A1A2A"/>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="RESTRICTED:" FontFamily="Consolas" FontSize="10" Foreground="#4A6B8A" CharacterSpacing="150"/>
                                        <TextBlock Text="✗  Incident data"          FontFamily="Consolas" FontSize="11" Foreground="#FF5252"/>
                                        <TextBlock Text="✗  Family records"         FontFamily="Consolas" FontSize="11" Foreground="#FF5252"/>
                                        <TextBlock Text="✗  Relief distributions"   FontFamily="Consolas" FontSize="11" Foreground="#FF5252"/>
                                        <TextBlock Text="✗  Evacuation center data" FontFamily="Consolas" FontSize="11" Foreground="#FF5252"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border x:Name="SidePanel" Grid.RowSpan="2" HorizontalAlignment="Right" Width="380"
                Background="#16202B" BorderThickness="1,0,0,0" BorderBrush="#2A3F52"
                Visibility="Collapsed">
            <ScrollViewer Padding="24,20">
                <StackPanel Spacing="16">
                    <Grid>
                        <TextBlock Text="{x:Bind ViewModel.PanelTitle, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   Foreground="White" CharacterSpacing="150" VerticalAlignment="Center"/>
                        <Button Content="✕" Click="ClosePanel_Click" HorizontalAlignment="Right"
                                Background="Transparent" Foreground="#4A6B8A" FontSize="16" Padding="8,4" BorderThickness="0"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#2A3F52"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="FULL NAME" FontFamily="Consolas" FontSize="10" Foreground="#A0B4C8" CharacterSpacing="150"/>
                        <Border Background="#1E2D3D" CornerRadius="3" BorderThickness="1" BorderBrush="#2A3F52">
                            <TextBox Text="{x:Bind ViewModel.FormFullName, Mode=TwoWay}"
                                     PlaceholderText="Full legal name"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" PlaceholderForeground="#4A6B8A"
                                     FontFamily="Consolas" FontSize="13" Padding="12,10"
                                     KeyDown="PanelField_KeyDown"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="EMAIL" FontFamily="Consolas" FontSize="10" Foreground="#A0B4C8" CharacterSpacing="150"/>
                        <Border Background="#1E2D3D" CornerRadius="3" BorderThickness="1" BorderBrush="#2A3F52">
                            <TextBox Text="{x:Bind ViewModel.FormEmail, Mode=TwoWay}"
                                     PlaceholderText="email@agency.gov.ph"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" PlaceholderForeground="#4A6B8A"
                                     FontFamily="Consolas" FontSize="13" Padding="12,10"
                                     KeyDown="PanelField_KeyDown"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="ROLE" FontFamily="Consolas" FontSize="10" Foreground="#A0B4C8" CharacterSpacing="150"/>
                        <Border Background="#1E2D3D" CornerRadius="3" BorderThickness="1" BorderBrush="#2A3F52">
                            <ComboBox ItemsSource="{x:Bind ViewModel.AssignableRoles}"
                                      SelectedItem="{x:Bind ViewModel.FormRole, Mode=TwoWay}"
                                      Background="Transparent" BorderThickness="0"
                                      Foreground="White" FontFamily="Consolas" FontSize="13"
                                      HorizontalAlignment="Stretch" Padding="8,10"/>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="BarangaySection" Spacing="6"
                                Visibility="{x:Bind ViewModel.ShowBarangayField, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="ASSIGNED BARANGAY" FontFamily="Consolas" FontSize="10" Foreground="#FF9B8A" CharacterSpacing="150"/>
                        <Border Background="#1E2D3D" CornerRadius="3" BorderThickness="1" BorderBrush="#FF9B8A">
                            <ComboBox ItemsSource="{x:Bind ViewModel.BarangayList}"
                                      SelectedItem="{x:Bind ViewModel.FormBarangay, Mode=TwoWay}"
                                      Background="Transparent" BorderThickness="0"
                                      Foreground="White" FontFamily="Consolas" FontSize="13"
                                      HorizontalAlignment="Stretch" Padding="8,10"/>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="PasswordSection" Spacing="6">
                        <TextBlock Text="PASSWORD" FontFamily="Consolas" FontSize="10" Foreground="#A0B4C8" CharacterSpacing="150"/>
                        <Border Background="#1E2D3D" CornerRadius="3" BorderThickness="1" BorderBrush="#2A3F52">
                            <PasswordBox x:Name="PanelPasswordBox"
                                         PlaceholderText="Min. 6 characters"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="White" FontFamily="Consolas" FontSize="13"
                                         Padding="12,10" PasswordRevealMode="Hidden"
                                         PasswordChanged="PanelPassword_Changed"
                                         KeyDown="PanelField_KeyDown"/>
                        </Border>
                    </StackPanel>

                    <Border x:Name="PanelErrorBanner" Background="#2D1A1A" CornerRadius="3"
                            Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="PanelErrorText" Foreground="#FF6B6B"
                                   FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <Button x:Name="SaveBtn" Click="SaveUser_Click"
                            HorizontalAlignment="Stretch" Height="48"
                            Background="#FF8070" CornerRadius="3">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B5B"/>
                        </Button.Resources>
                        <TextBlock x:Name="SaveBtnText" Text="CREATE OPERATOR"
                                   FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A1A1A" CharacterSpacing="100"/>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
