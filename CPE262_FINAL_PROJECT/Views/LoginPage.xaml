<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPE262_FINAL_PROJECT.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D1B2A">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="ms-appx:///Assets/BACKROUND.png"
                        Stretch="UniformToFill"
                        Opacity="0.45"/>
        </Grid.Background>
        <Rectangle Fill="#880D1B2A"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>

        <TextBlock x:Name="ClockText"
                   Text="TIME: --:--:-- PST"
                   VerticalAlignment="Top" HorizontalAlignment="Left"
                   Margin="20,16,0,0"
                   Foreground="#4A6B8A" FontSize="11" FontFamily="Consolas"/>

        <Border Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#16202B"
                CornerRadius="4"
                BorderThickness="0,3,0,0"
                BorderBrush="#FF7B6B"
                Padding="40,36,40,40">
            <StackPanel Spacing="0">

                <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="FIRETRACK" FontSize="26" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="White"
                                   VerticalAlignment="Center" CharacterSpacing="150"/>
                    </StackPanel>
                    <TextBlock Text="COMMAND CENTER ACCESS" FontSize="11" FontFamily="Consolas"
                               Foreground="#FF9B8A" HorizontalAlignment="Center" CharacterSpacing="200"/>
                </StackPanel>

                <TextBlock Text="OPERATOR EMAIL" FontSize="11" FontFamily="Consolas"
                           FontWeight="SemiBold" Foreground="#A0B4C8"
                           CharacterSpacing="150" Margin="0,0,0,8"/>

                <Border x:Name="EmailBorder"
                        Background="#1E2D3D" CornerRadius="3" BorderThickness="1"
                        BorderBrush="#2A3F52" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="EmailIcon"
                                   Grid.Column="0" Text="&#xE77B;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="#4A6B8A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox x:Name="EmailBox" Grid.Column="1"
                                 Text="{x:Bind ViewModel.Email, Mode=TwoWay}"
                                 PlaceholderText="operator@firetrack.com"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#1A1A1A" PlaceholderForeground="#4A6B8A"
                                 FontFamily="Consolas" FontSize="13"
                                 Padding="0,12,12,12" VerticalAlignment="Center"
                                 GotFocus="EmailBox_GotFocus"
                                 LostFocus="EmailBox_LostFocus"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,8">
                    <TextBlock Text="PASSWORD" FontSize="11" FontFamily="Consolas"
                               FontWeight="SemiBold" Foreground="#A0B4C8"
                               CharacterSpacing="150" HorizontalAlignment="Left"/>
                </Grid>

                <Border x:Name="PasswordBorder"
                        Background="#1E2D3D" CornerRadius="3" BorderThickness="1"
                        BorderBrush="#2A3F52" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PasswordIcon"
                                   Grid.Column="0" Text="&#xE8D7;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="#4A6B8A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="PasswordBox" Grid.Column="1"
                                     PlaceholderText="Enter password here"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#4A6B8A"
                                     FontFamily="Consolas" FontSize="13"
                                     Padding="0,12,12,12" VerticalAlignment="Center"
                                     PasswordRevealMode="Hidden"
                                     PasswordChanged="PasswordBox_PasswordChanged"
                                     GotFocus="PasswordBox_GotFocus"
                                     LostFocus="PasswordBox_LostFocus"/>
                    </Grid>
                </Border>

                <Border x:Name="ErrorBanner" Background="#2D1A1A" CornerRadius="3"
                        Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#FF6B6B"
                               FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <Button x:Name="LoginBtn" Command="{x:Bind ViewModel.LoginCommand}"
                        HorizontalAlignment="Stretch" Height="52"
                        Background="#FF8070" CornerRadius="3" Margin="0,0,0,20">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF6B5B"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#E55A4A"/>
                    </Button.Resources>
                    <Grid HorizontalAlignment="Center">
                        <StackPanel x:Name="NormalState" Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="ESTABLISH CONNECTION"
                                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="#1A1A1A" CharacterSpacing="100" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="LoadingState" Orientation="Horizontal"
                                    Spacing="10" Visibility="Collapsed">
                            <ProgressRing IsActive="True" Width="18" Height="18" Foreground="#1A1A1A"/>
                            <TextBlock Text="AUTHENTICATING..."
                                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="#1A1A1A" CharacterSpacing="100" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <Grid Margin="0,0,0,16">
                    <Rectangle Height="1" Fill="#2A3F52"/>
                    <Border Background="#16202B" Padding="10,0" HorizontalAlignment="Center">
                        <TextBlock Text="OR" Foreground="#4A6B8A" FontFamily="Consolas" FontSize="11"/>
                    </Border>
                </Grid>

                <HyperlinkButton Content="REQUEST ACCESS — REGISTER NEW CITIZEN"
                                 HorizontalAlignment="Center"
                                 FontFamily="Consolas" FontSize="11" Foreground="#FF9B8A"
                                 Click="RegisterLink_Click"/>

                <Border Background="#1E2D3D" CornerRadius="20" Padding="14,6"
                        Margin="0,24,0,0" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="7" Height="7" Fill="#4CAF50" VerticalAlignment="Center"/>
                        <TextBlock Text="NETWORK SECURE: REGION VII"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#A0B4C8" CharacterSpacing="100"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Margin="0,0,0,16" Spacing="6">
            <TextBlock Text="THE OPERATORS"
                       FontFamily="Consolas" FontSize="11" Foreground="#4A6B8A"
                       HorizontalAlignment="Center" CharacterSpacing="200"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="BFP  |"          Foreground="#4A6B8A" FontFamily="Consolas" FontSize="11" CharacterSpacing="150"/>
                <TextBlock Text="DSWD  |"         Foreground="#4A6B8A" FontFamily="Consolas" FontSize="11" CharacterSpacing="150"/>
                <TextBlock Text="BARANGAY OPS  |" Foreground="#4A6B8A" FontFamily="Consolas" FontSize="11" CharacterSpacing="150"/>
                <TextBlock Text="CITIZEN"          Foreground="#4A6B8A" FontFamily="Consolas" FontSize="11" CharacterSpacing="150"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Page>
